FROM node:20-slim

WORKDIR /app

# نسخ ملفات التبعيات أولاً للاستفادة من كاش Docker
COPY package.json package-lock.json ./

# تثبيت التبعيات فقط - بدون devDependencies
RUN npm ci --only=production --legacy-peer-deps --no-audit --prefer-offline

# نسخ باقي الملفات
COPY . .

# إنشاء المجلدات الضرورية
RUN mkdir -p systems script/commands/data script/commands/cache backup logs

# المنفذ
EXPOSE 8000

# تشغيل التطبيق
CMD ["node", "index.js"]
