  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "node --test",
    "setup": "npm install",
    "clean": "rm -rf node_modules package-lock.json",
    "update": "npm update --save",
    "version": "echo 'Node.js v24.11.0 | KIRA Supreme v24.11.0'",
    "docker:build": "docker build -t kira-supreme .",
    "docker:run": "docker run -p 8000:8000 -d kira-supreme",
    "health": "curl -f http://localhost:8000/health || echo 'Server not running'"
  },
