    "sqlite3": "^5.1.7",
    "string-similarity": "^4.0.4",
    "gradient-string": "^2.0.2",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.4.5",
    "winston": "^3.13.0",
    "socket.io": "^4.7.5",
    "openai": "^4.47.1",
    "tesseract.js": "^5.0.5",
    "qrcode": "^1.5.4",
