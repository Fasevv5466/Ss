# Bot Configuration
NODE_ENV=production
PORT=8000
APPSTATE_PATH=appstate.json
TIMEZONE=Africa/Casablanca

# Facebook API Settings
FCA_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
FCA_LISTEN_EVENTS=true
FCA_LISTEN_TYPING=false
FCA_UPDATE_PRESENCE=false
FCA_FORCE_LOGIN=false

# Database
DB_TYPE=sqlite
DB_PATH=./data/kira.db

# Security
ADMIN_IDS=["100000000000000"]
ENCRYPTION_KEY=your-secret-key-here

# Features
ENABLE_NSFW=false
MAX_UPLOAD_SIZE=50
COMMAND_COOLDOWN=2

# Logging
LOG_LEVEL=info
DEBUG=false
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/kira.log

# OpenAI (if using AI features)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-3.5-turbo
